          // 4. ENGINEERING & AI
          FRONTEND_WIZARD: { id: 'FRONTEND_WIZARD', name: 'Frontend Wizard', icon: 'fa-solid fa-terminal', color: 'bg-blue-500', role: 'ผู้เชี่ยวชาญด้าน UI/UX และ Frontend เน้นความสวยงาม' },
