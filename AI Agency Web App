                    <div className="flex flex-wrap gap-2 mb-3 px-1">
                      <button onClick={() => handleRefinePrompt('expand')} disabled={isRefining || !inputValue.trim() || isProcessing} className="text-[11px] bg-purple-100 text-purple-700 px-3 py-1.5 rounded-full font-bold hover:bg-purple-200 transition flex items-center shadow-sm disabled:opacity-50">
                        {isRefining ? <i className="fa-solid fa-spinner fa-spin mr-1.5"></i> : <i className="fa-solid fa-wand-magic-sparkles mr-1.5"></i>} เสกคำสั่งให้สมบูรณ์ ✨
                      </button>
                      <button onClick={() => handleRefinePrompt('risk')} disabled={isRefining || !inputValue.trim() || isProcessing} className="text-[11px] bg-amber-100 text-amber-700 px-3 py-1.5 rounded-full font-bold hover:bg-amber-200 transition flex items-center shadow-sm disabled:opacity-50">
                        {isRefining ? <i className="fa-solid fa-spinner fa-spin mr-1.5"></i> : <i className="fa-solid fa-shield-halved mr-1.5"></i>} ประเมินความเสี่ยง ✨
                      </button>
                    </div>

                    <div className="relative flex items-end space-x-3">
                      <div className="flex-1 bg-slate-50 border border-slate-300 rounded-2xl shadow-inner focus-within:ring-4 focus-within:ring-purple-500/10 focus-within:border-purple-400 transition-all duration-300">
                        <textarea
                          value={inputValue} onChange={(e) => setInputValue(e.target.value)} onKeyDown={handleKeyDown}
                          placeholder="พิมพ์คำสั่ง... (เช่น 'ให้ทีมนักเทรดเช็คราคา XAUUSD สดๆ หน่อย' หรือ 'หาร้านโอมากาเสะฉลองวันเกิด')"
                          className="w-full bg-transparent border-none focus:ring-0 p-4 max-h-48 min-h-[60px] resize-none text-[13.5px] text-slate-800 placeholder-slate-400 font-medium outline-none"
                          rows="2" disabled={isProcessing || isRefining}
                        />
                      </div>
                      <button
                        onClick={handleSend} disabled={!inputValue.trim() || isProcessing || isRefining}
                        className={`p-4 h-[60px] w-[60px] rounded-2xl flex items-center justify-center transition-all duration-300 ${!inputValue.trim() || isProcessing || isRefining ? 'bg-slate-100 text-slate-400 cursor-not-allowed border border-slate-200' : 'bg-slate-900 text-white hover:bg-purple-700 shadow-md hover:shadow-lg hover:-translate-y-1'}`}
                      >
                        {isProcessing || isRefining ? <i className="fa-solid fa-spinner fa-spin text-xl"></i> : <i className="fa-solid fa-paper-plane text-xl"></i>}
                      </button>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
