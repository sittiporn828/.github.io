          // 5. DESIGN & CREATIVE
          UI_UX_DESIGNER: { id: 'UI_UX_DESIGNER', name: 'UI/UX Designer', icon: 'fa-solid fa-pen-nib', color: 'bg-pink-500', role: 'ออกแบบประสบการณ์ผู้ใช้ สร้าง Wireframe' },
          BRAND_GUARDIAN: { id: 'BRAND_GUARDIAN', name: 'Brand Guardian', icon: 'fa-solid fa-shield', color: 'bg-rose-500', role: 'ผู้รักษาอัตลักษณ์แบรนด์ ควบคุมฟอนต์และโทนสี' },
          WHIMSY_INJECTOR: { id: 'WHIMSY_INJECTOR', name: 'Whimsy Injector', icon: 'fa-solid fa-wand-magic-sparkles', color: 'bg-fuchsia-500', role: 'เติมกิมมิคความขบขันและลูกเล่นสร้างสรรค์ ให้โปรดักต์มีชีวิตชีวา' },

          // 6. MARKETING & SALES
          GROWTH_HACKER: { id: 'GROWTH_HACKER', name: 'Marketing Growth Hacker', icon: 'fa-solid fa-arrow-trend-up', color: 'bg-green-500', role: 'ผู้เชี่ยวชาญการหาช่องทางเติบโตแบบก้าวกระโดด' },
          REDDIT_NINJA: { id: 'REDDIT_NINJA', name: 'Reddit Community Ninja', icon: 'fa-solid fa-users', color: 'bg-orange-500', role: 'นักการตลาดแบบกองโจร รู้วิธีแทรกซึมชุมชนออนไลน์' },
          SALES_DIRECTOR: { id: 'SALES_DIRECTOR', name: 'B2B Sales Director', icon: 'fa-solid fa-bullseye', color: 'bg-red-500', role: 'ปิดการขาย เจรจาธุรกิจกับลูกค้ารายใหญ่เพื่อหารายได้เข้าบริษัท' },
          COPYWRITER: { id: 'COPYWRITER', name: 'Expert Copywriter', icon: 'fa-solid fa-font', color: 'bg-yellow-600', role: 'นักเขียนคำโฆษณาที่โน้มน้าวใจลูกค้า' },

          // 7. QA, SECURITY & SUPPORT
          QA_TESTER: { id: 'QA_TESTER', name: 'Strict QA Tester', icon: 'fa-solid fa-bug', color: 'bg-red-500', role: 'ผู้ทดสอบระบบสุดโหด ค้นหาบั๊ก' },
          SECURITY_ENGINEER: { id: 'SECURITY_ENGINEER', name: 'Security Engineer', icon: 'fa-solid fa-user-secret', color: 'bg-red-800', role: 'หาช่องโหว่และป้องกันระบบจากการถูกแฮ็ก' },
          REALITY_CHECKER: { id: 'REALITY_CHECKER', name: 'Reality Checker', icon: 'fa-solid fa-circle-exclamation', color: 'bg-amber-600', role: 'ประเมินความเป็นไปได้และหาจุดบอดของโปรเจกต์' },
          CUSTOMER_SUPPORT: { id: 'CUSTOMER_SUPPORT', name: 'Customer Success', icon: 'fa-solid fa-headset', color: 'bg-sky-400', role: 'ดูแลลูกค้า แก้ปัญหาการใช้งาน สร้างความประทับใจหลังการขาย' },

          // 8. DATA & RESEARCH
          DATA_SCIENTIST: { id: 'DATA_SCIENTIST', name: 'Data Scientist', icon: 'fa-solid fa-database', color: 'bg-sky-500', role: 'วิเคราะห์ข้อมูลขนาดใหญ่ ทำโมเดลพยากรณ์' },
          MARKET_RESEARCHER: { id: 'MARKET_RESEARCHER', name: 'Market Researcher', icon: 'fa-solid fa-chart-pie', color: 'bg-violet-500', role: 'วิจัยตลาดและพฤติกรรมผู้บริโภค' },

          // 9. PERSONAL & LIFESTYLE
          LIFESTYLE_CONCIERGE: { id: 'LIFESTYLE_CONCIERGE', name: 'Lifestyle Concierge', icon: 'fa-solid fa-mug-hot', color: 'bg-yellow-500', role: 'ผู้ช่วยส่วนตัว จองตั๋วเครื่องบิน ร้านอาหาร วางแผนท่องเที่ยว และธุระจิปาถะ' },
          PERSONAL_TRAINER: { id: 'PERSONAL_TRAINER', name: 'Personal Health Coach', icon: 'fa-solid fa-heart-pulse', color: 'bg-green-600', role: 'ดูแลสุขภาพ จัดตารางโภชนาการ และการออกกำลังกายให้ CEO' },
          PRIVATE_WEALTH: { id: 'PRIVATE_WEALTH', name: 'Private Wealth Manager', icon: 'fa-solid fa-wallet', color: 'bg-amber-600', role: 'จัดการทรัพย์สินส่วนตัว การลงทุนส่วนบุคคล และความมั่งคั่งของครอบครัว' }
        };

        const DEPARTMENTS = {
          'Management & HR': ['SECRETARY', 'PROJECT_MANAGER', 'HR_MANAGER'],
          'Finance & Investment': ['CFO', 'QUANT_TRADER', 'VENTURE_CAPITALIST', 'RISK_MANAGER'],
          'Legal': ['CORPORATE_LAWYER'],
          'Engineering & AI': ['FRONTEND_WIZARD', 'BACKEND_ARCHITECT', 'MOBILE_DEVELOPER', 'DEV_OPS', 'AI_ENGINEER'],
          'Design & Creative': ['UI_UX_DESIGNER', 'BRAND_GUARDIAN', 'WHIMSY_INJECTOR'],
          'Marketing & Sales': ['GROWTH_HACKER', 'REDDIT_NINJA', 'SALES_DIRECTOR', 'COPYWRITER'],
          'QA, Security & Support': ['QA_TESTER', 'SECURITY_ENGINEER', 'REALITY_CHECKER', 'CUSTOMER_SUPPORT'],
          'Data & Research': ['DATA_SCIENTIST', 'MARKET_RESEARCHER'],
          'Personal & Lifestyle': ['LIFESTYLE_CONCIERGE', 'PERSONAL_TRAINER', 'PRIVATE_WEALTH']
        };

        function App() {
          // --- State Management ---
          const [apiKey, setApiKey] = useState(localStorage.getItem('gemini_api_key') || '');
          const [showApiModal, setShowApiModal] = useState(!localStorage.getItem('gemini_api_key'));
          const [apiKeyInput, setApiKeyInput] = useState('');
          
          const [messages, setMessages] = useState([
            {
              id: 1,
              sender: 'SECRETARY',
              type: 'text',
              content: 'สวัสดีค่ะท่านประธาน ดิฉันพร้อมให้บริการผ่านระบบ Web Application แล้วค่ะ!\n\n(หากนี่เป็นการใช้งานครั้งแรก กรุณาตั้งค่า API Key เพื่อเปิดระบบสมองกลของบริษัทให้เต็มรูปแบบค่ะ)',
              timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
            }
          ]);
          const [inputValue, setInputValue] = useState('');
          const [isProcessing, setIsProcessing] = useState(false);
          const [isRefining, setIsRefining] = useState(false);
          const [activeTasks, setActiveTasks] = useState([]);
          const [pastProjects, setPastProjects] = useState([]);
          const messagesEndRef = useRef(null);

          useEffect(() => {
            messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
          }, [messages, activeTasks]);

          // --- API Setup Logic ---
          const saveApiKey = () => {
              if (apiKeyInput.trim().length > 10) {
                  localStorage.setItem('gemini_api_key', apiKeyInput.trim());
                  setApiKey(apiKeyInput.trim());
                  setShowApiModal(false);
              } else {
                  alert('กรุณากรอก API Key ให้ถูกต้อง');
              }
          };

          const logout = () => {
              localStorage.removeItem('gemini_api_key');
              setApiKey('');
              setShowApiModal(true);
          }

          // --- Audio Helpers ---
          const base64ToArrayBuffer = (base64) => {
            const binary_string = window.atob(base64);
            const len = binary_string.length;
            const bytes = new Uint8Array(len);
            for (let i = 0; i < len; i++) { bytes[i] = binary_string.charCodeAt(i); }
            return bytes.buffer;
          };

          const pcmToWav = (pcmData, sampleRate) => {
            const numChannels = 1; const bitsPerSample = 16;
            const byteRate = (sampleRate * numChannels * bitsPerSample) / 8;
            const blockAlign = (numChannels * bitsPerSample) / 8;
            const dataSize = pcmData.byteLength;
            const buffer = new ArrayBuffer(44 + dataSize);
            const view = new DataView(buffer);

            const writeString = (view, offset, string) => {
              for (let i = 0; i < string.length; i++) { view.setUint8(offset + i, string.charCodeAt(i)); }
            };

            writeString(view, 0, 'RIFF'); view.setUint32(4, 36 + dataSize, true);
            writeString(view, 8, 'WAVE'); writeString(view, 12, 'fmt ');
            view.setUint32(16, 16, true); view.setUint16(20, 1, true);
            view.setUint16(22, numChannels, true); view.setUint32(24, sampleRate, true);
            view.setUint32(28, byteRate, true); view.setUint16(32, blockAlign, true);
            view.setUint16(34, bitsPerSample, true); writeString(view, 36, 'data');
            view.setUint32(40, dataSize, true);

            const pcmBytes = new Uint8Array(pcmData);
            const wavBytes = new Uint8Array(buffer, 44);
            wavBytes.set(pcmBytes);
            return buffer;
          };

          // --- Gemini API Caller ---
          const callGemini = async (prompt, systemInstruction, responseSchema = null, useSearch = false) => {
            if (!apiKey) throw new Error("API Key is missing!");

            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
              contents: [{ parts: [{ text: prompt }] }],
              systemInstruction: { parts: [{ text: systemInstruction }] },
            };

            if (useSearch) payload.tools = [{ google_search: {} }];
            if (responseSchema) {
              payload.generationConfig = {
                responseMimeType: "application/json",
                responseSchema: responseSchema
              };
            }

            let retries = 5; let delay = 1000;
            while (retries > 0) {
              try {
                const response = await fetch(url, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(payload)
                });
                
                if (!response.ok) {
                    const errData = await response.json();
                    throw new Error(errData.error?.message || `HTTP ${response.status}`);
                }
                
                const data = await response.json();
                const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
                return responseSchema ? JSON.parse(text) : text;
              } catch (error) {
                retries--;
                if (retries === 0) throw error; 
                await new Promise(res => setTimeout(res, delay));
                delay *= 2;
              }
            }
          };

          // --- LLM Features ---
          const handleRefinePrompt = async (mode) => {
            if (!inputValue.trim() || !apiKey) return;
            setIsRefining(true);
            try {
              let sysInstruction = "";
              let promptMsg = inputValue;
              
              if (mode === 'expand') {
                sysInstruction = "คุณคือ AI ผู้เชี่ยวชาญด้าน Prompt Engineering ประจำตัว CEO นำไอเดียสั้นๆ ของ CEO มาขยายเป็น 'คำสั่งผู้บริหาร (Executive Directive)' ที่ครอบคลุม เป็นทางการ ระบุเป้าหมายชัดเจน ตอบกลับเฉพาะข้อความที่ขยายแล้ว ภาษาไทย";
              } else if (mode === 'risk') {
                sysInstruction = "คุณคือที่ปรึกษาความเสี่ยง ประเมินคำสั่งต่อไปนี้และสรุป 'ความเสี่ยงหลักที่ซ่อนอยู่' 3 ข้อ พร้อมคำแนะนำรับมือสั้นๆ ตอบเป็น bullet ภาษาไทย";
              }
              
              const result = await callGemini(promptMsg, sysInstruction, null, false);
              
              if (mode === 'expand') setInputValue(result.trim());
              else if (mode === 'risk') {
                setMessages(prev => [...prev, {
                  id: Date.now(),
                  sender: 'SECRETARY',
                  type: 'text',
                  content: `⚠️ ท่านประธานคะ ดิฉันได้ทำการประเมินความเสี่ยงเบื้องต้นมาให้ค่ะ:\n\n${result}`,
                  timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                }]);
              }
            } catch (e) {
              setMessages(prev => [...prev, { id: Date.now(), sender: 'SECRETARY', type: 'error', content: `วิเคราะห์ขัดข้อง (${e.message})`, timestamp: new Date().toLocaleTimeString() }]);
            } finally { setIsRefining(false); }
          };

          const handleDraftEmail = async (project) => {
            if (!apiKey) return;
            setIsProcessing(true);
            try {
              const sysInstruction = "คุณคือ Chief Communications Officer เขียนร่างอีเมลประกาศบริษัท (Company-wide Announcement) แจ้งให้พนักงานทราบวิสัยทัศน์หรือข่าวดี เขียนให้ดูมีพลังและมืออาชีพ ภาษาไทย";
              const promptMsg = `ชื่อเรื่อง: ${project.name}\nสรุป: ${project.memory}\nร่างอีเมลประกาศให้ที`;
              
              setActiveTasks([{ id: 'email', agent: 'SECRETARY', status: 'working', text: 'กำลังร่างประกาศ...' }]);
              const result = await callGemini(promptMsg, sysInstruction, null, false);
              
              setMessages(prev => [...prev, {
                id: Date.now(), sender: 'SECRETARY', type: 'report', 
                content: `### 📧 ร่างประกาศบริษัท\n\n${result}`, timestamp: new Date().toLocaleTimeString()
              }]);
            } catch (e) { console.error(e); } 
            finally { setIsProcessing(false); setActiveTasks([]); }
          };

          const handlePlayAudio = async (text, messageId) => {
            setMessages(prev => prev.map(m => m.id === messageId ? { ...m, isAudioLoading: true } : m));
            try {
              const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`;
              const payload = {
                contents: [{ parts: [{ text: `เรียนท่านประธาน สรุปคือ: ${text}` }] }],
                generationConfig: { responseModalities: ["AUDIO"], speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Aoede" } } } }
              };
              
              const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
              if (!response.ok) throw new Error("TTS failed");
              
              const data = await response.json();
              const inlineData = data.candidates?.[0]?.content?.parts?.[0]?.inlineData;
              if (!inlineData) throw new Error("No audio data");
              
              const match = inlineData.mimeType.match(/rate=(\d+)/);
              const sampleRate = match ? parseInt(match[1]) : 24000;
              const pcmBuffer = base64ToArrayBuffer(inlineData.data);
              const wavBuffer = pcmToWav(pcmBuffer, sampleRate);
              const blob = new Blob([wavBuffer], { type: 'audio/wav' });
              const audioUrl = URL.createObjectURL(blob);
              
              setMessages(prev => prev.map(m => m.id === messageId ? { ...m, isAudioLoading: false, audioUrl } : m));
            } catch (error) {
              setMessages(prev => prev.map(m => m.id === messageId ? { ...m, isAudioLoading: false, audioError: true } : m));
            }
          };

          // --- Chat Execution Logic ---
          const handleSend = async () => {
            if (!inputValue.trim() || isProcessing || !apiKey) return;

            const userMsg = inputValue.trim();
            setInputValue('');
            
            setMessages(prev => [...prev, {
              id: Date.now(), sender: 'CEO', type: 'text', content: userMsg, timestamp: new Date().toLocaleTimeString()
            }]);
            setIsProcessing(true);

            const memoryContext = pastProjects.length > 0 
              ? `\n\n[Memory: ประวัติงาน/ข้อมูลส่วนตัวของ CEO]\n${pastProjects.map((p, i) => `${i+1}. เรื่อง: ${p.name} - ข้อมูล: ${p.memory}`).join('\n')}\n*อ้างอิงเสมอ*`
              : '';

            try {
              // 1. ROUTING
              setActiveTasks([{ id: 'routing', agent: 'SECRETARY', status: 'thinking', text: 'กำลังจัดสรรทีม...' }]);
              
              const routerSystemPrompt = `คุณคือ "Universal Executive Assistant" ประจำตัว CEO ดูแลทั้งธุรกิจและชีวิตส่วนตัว
แยกแยะว่าคำสั่งเป็นเรื่องงานหรือส่วนตัว แล้วเลือกแผนกที่เหมาะสม (3-6 แผนก) จาก:
