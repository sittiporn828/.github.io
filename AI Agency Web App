          MOBILE_DEVELOPER: { id: 'MOBILE_DEVELOPER', name: 'Mobile Developer', icon: 'fa-solid fa-mobile-screen', color: 'bg-teal-600', role: 'ผู้พัฒนาแอปพลิเคชัน iOS และ Android' },
